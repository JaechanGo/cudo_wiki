# CUDO 사내 위키 — 환경변수 예시. 복사해서 사용: cp .env.example .env
# ★ 모든 시크릿은 placeholder(값 비움). 실제 값은 .env 에만 채우고 절대 커밋 금지.

# ── Database ─────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=cudo_wiki
DB_USER=cudo
DB_PASSWORD=            # ★ placeholder — 실제 비번 채우고 커밋 금지

# ── LLM gateway (GLM-5.2 via 사내 LiteLLM) ─
LITELLM_BASE=http://litellm:4000/v1
LITELLM_KEY_GLM=        # ★ placeholder

# ── OCR shim ─────────────────────────────
OCR_BASE=http://ocr-shim:8900

# ── BizBox 그룹웨어 크롤(서비스계정) ───────
BIZBOX_BASE=http://gw.cudo.co.kr
BIZBOX_USER=            # ★ placeholder
BIZBOX_PASSWORD=        # ★ placeholder

# ── MCP server ───────────────────────────
MCP_PORT=8080           # 내부 전용(호스트 비노출)
LOG_LEVEL=INFO
